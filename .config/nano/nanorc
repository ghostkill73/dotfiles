# nanorc
include "/usr/share/nano/*.nanorc"
include "/usr/share/nano/extra/*.nanorc"

# Options
set tabsize 4
#set tabstospaces
set linenumbers
set numbercolor yellow,normal
set scrollercolor grey,normal
set indicator
set smarthome
set afterends
set wordchars "_"
set zap
set atblanks
set historylog
set multibuffer
set mouse
#set locking
#set nohelp

unbind ^/				  main
unbind ^J				  main
unbind M-J				  main
unbind M-U				  main
unbind M-/				  main
unbind M-R				  main

bind ^Q     exit          all
bind ^Z     undo          main
bind ^C     copy          main
bind ^V     paste         main
bind ^X     cut           main
bind ^K     zap           main
bind ^H     chopwordleft  all
bind ^/     comment       main
bind ^Space complete      main

bind M-C    location      main
bind ^E     wherewas      all
bind M-E    findprevious  all
bind ^R     replace       main
bind ^_     gotoline      main
bind ^G     firstline     all
bind M-G    lastline      all
bind ^B     pageup        all
bind ^F     pagedown      all

bind M-1    help          all
#bind Sh-M-C constantshow  main
bind Sh-M-F formatter     main
#bind Sh-M-B linter        main
bind Sh-M-i linter        main
